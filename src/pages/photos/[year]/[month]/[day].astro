---
import BaseHead from "../../../../components/BaseHead.astro";
import Nav from "../../../../components/Nav.astro";
import { AUTHOR_NAME, SITE_TITLE } from "../../../../consts";
import {
	getPhotosByDate,
	getPreviousNextDay,
	dailyPhotos,
} from "../../../../data/photoOfTheDay";

const MONTH_NAMES = [
	"January",
	"February",
	"March",
	"April",
	"May",
	"June",
	"July",
	"August",
	"September",
	"October",
	"November",
	"December",
];

export async function getStaticPaths() {
	return dailyPhotos.map((p) => {
		const [y, m, d] = p.date.split("-").map(Number);
		return {
			params: {
				year: String(y),
				month: String(m),
				day: String(d),
			},
		};
	});
}

const { year: yearStr, month: monthStr, day: dayStr } = Astro.params;
const year = Number(yearStr);
const month = Number(monthStr);
const day = Number(dayStr);
const dateStr = `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

const photosByDate = getPhotosByDate();
const photo = photosByDate.get(dateStr);

if (!photo) {
	return Astro.redirect("/photos");
}

const monthName = MONTH_NAMES[month - 1];
const backHref = `/photos/${year}/${month}`;
const { prev: prevDateStr, next: nextDateStr } = getPreviousNextDay(dateStr);
const prevHref = prevDateStr
	? (() => {
			const [y, m, d] = prevDateStr.split("-").map(Number);
			return `/photos/${y}/${m}/${d}`;
		})()
	: null;
const nextHref = nextDateStr
	? (() => {
			const [y, m, d] = nextDateStr.split("-").map(Number);
			return `/photos/${y}/${m}/${d}`;
		})()
	: null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${monthName} ${day}, ${year} | Photos | ${SITE_TITLE}`}
			description={photo.alt ??
				`Photo of the day for ${monthName} ${day}, ${year}`}
		/>
	</head>
	<body
		class="bg-[var(--off-white)] min-h-screen flex flex-col overflow-x-hidden"
	>
		<Nav currentPath={Astro.url.pathname} />
		<main
			class="w-full max-w-4xl mx-auto px-4 pt-24 lg:pt-12 pb-16 flex-1 flex flex-col justify-center min-h-[100dvh] min-w-0"
		>
			<header class="mb-6">
				<div class="flex flex-row justify-between items-center">
					<div class="flex flex-col gap-2">
						<a
							href={backHref}
							class="inline-flex items-center gap-2 font-mono text-sm text-secondary no-underline hover:text-primary mb-4"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M15 18l-6-6 6-6"></path>
							</svg>
							Back to {monthName}
							{year}
						</a>
						<h1 class="font-mono text-primary text-xl font-semibold m-0">
							{monthName}
							{day}, {year}
						</h1>
						<p class="font-mono text-secondary text-sm m-0 mt-1">
							Photo of the Day · {AUTHOR_NAME}
						</p>
					</div>
					<div class="flex justify-end gap-2 mb-4">
						{
							prevHref ? (
								<a
									href={prevHref}
									class="flex items-center justify-center w-10 h-10 rounded-full bg-white border border-[var(--border-subtle)] text-primary no-underline hover:bg-[var(--off-white)] transition-colors"
									aria-label="Previous day"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="20"
										height="20"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true"
									>
										<path d="M15 18l-6-6 6-6" />
									</svg>
								</a>
							) : null
						}
						{
							nextHref ? (
								<a
									href={nextHref}
									class="flex items-center justify-center w-10 h-10 rounded-full bg-white border border-[var(--border-subtle)] text-primary no-underline hover:bg-[var(--off-white)] transition-colors"
									aria-label="Next day"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="20"
										height="20"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true"
									>
										<path d="M9 18l6-6-6-6" />
									</svg>
								</a>
							) : null
						}
					</div>
				</div>
			</header>

			<figure class="m-0">
				<div class="overflow-hidden bg-[var(--off-white)]">
					<img
						src={photo.src}
						alt={photo.alt ?? `Photo for ${dateStr}`}
						class="w-full h-auto block"
					/>
				</div>
				{
					photo.alt && (
						<figcaption class="font-mono text-sm text-secondary mt-3 italic">
							{photo.alt}
						</figcaption>
					)
				}
			</figure>
		</main>
	</body>
</html>
